{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/shared/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/",        "destination": "/presence/index.html" },
    { "source": "/order",   "destination": "/orders/index.html"   },
    { "source": "/catering","destination": "/catering/index.html" },
    { "source": "/insights","destination": "/insights/index.html" }
  ],
  "env": {
    "RESTAURANT_SLUG": "@restaurant_slug",
    "KRAVON_API_URL":  "@kravon_api_url"
  }
}
