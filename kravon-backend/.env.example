# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated allowed origins, or * to allow all (dev only)
CORS_ORIGIN=http://localhost:5173

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=kravon_db
# Set to "true" when connecting to a hosted/cloud database that requires SSL
DB_SSL=false

# ─── Auth (JWT) ──────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Optional: External Services ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG....
# CLOUDINARY_URL=cloudinary://...
